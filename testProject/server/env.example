# ─── Server environment variables (.env) ──────────────────────────────────────
# Copy this to .env and fill in your values

# MongoDB Atlas connection string
# Get from: Atlas Dashboard > Connect > Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/quiz_app?retryWrites=true&w=majority

# A secret key your frontend uses to authenticate with your server
# Make this a long random string (e.g. openssl rand -hex 32)
API_KEY=replace-with-a-long-random-secret

# Port for the server (optional, defaults to 3001)
PORT=3001


# ─── Frontend environment variables (.env in your Vite project) ───────────────
# Add these to your frontend project root

# URL where your new server is deployed
VITE_API_URL=http://localhost:3001

# Same API_KEY value as above
VITE_API_KEY=replace-with-a-long-random-secret
